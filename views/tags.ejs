<%- include('partials/header', { title: '算法标签' }) %>
<section class="section"><div class="container">
<div class="page-header"><h1 class="page-title">算法标签库</h1><p class="page-desc">选择算法方向，查看相关题目</p></div>
<% if (tags.length === 0) { %>
<div class="empty-state"><span class="empty-icon">🏷️</span><p>还没有标签。</p></div>
<% } else { %>
<div class="tags-grid">
  <% const icons = { '动态规划': '🧩', '贪心': '🎯', '二分查找': '🔍', 'DFS/BFS': '🌊', '字符串': '📝', '数学': '🔢', '数据结构': '🏗️', '图论': '🕸️', '排序': '📊', '双指针': '👉', '位运算': '💿', '回溯': '🔄', '滑动窗口': '🪟', '前缀和': '📐', '并查集': '🔗' }; %>
  <% tags.forEach(function(t) { %>
  <a href="/tags/<%= encodeURIComponent(t.name) %>" class="tag-card">
    <div class="tag-card-icon" style="background:<%= t.color %>20;"><span style="color:<%= t.color %>;font-size:2rem;"><%= icons[t.name] || '💡' %></span></div>
    <div class="tag-card-body"><h3 class="tag-card-name" style="color:<%= t.color %>;"><%= t.name %></h3><span class="tag-card-count"><%= t.problem_count %> 道题目</span></div>
    <div class="tag-card-arrow">&rarr;</div>
  </a>
  <% }); %>
</div>
<% } %>
</div></section>
<%- include('partials/footer') %>
