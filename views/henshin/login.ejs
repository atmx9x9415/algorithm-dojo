<%- include('../partials/header', { title: '登录' }) %>
<section class="section"><div class="container">
<div class="auth-wrapper">
  <div class="auth-card">
    <h2 class="auth-title">登录</h2>
    <p class="auth-subtitle">登录后可以上传题目和题解</p>
    <div class="auth-links">
      <span>还没有账号？</span><a href="/henshin/register">注册新账号</a>
    </div>
    <% if (typeof error !== 'undefined' && error) { %><div class="alert alert-error"><%= error %></div><% } %>
    <form method="POST" action="/henshin/login" class="auth-form">
      <div class="form-group">
        <label for="email">邮箱</label>
        <input type="email" id="email" name="email" class="form-input" value="<%= typeof email !== 'undefined' ? email : '' %>" placeholder="your@email.com" maxlength="100" required autocomplete="email">
      </div>
      <div class="form-group">
        <label for="password">密码</label>
        <input type="password" id="password" name="password" class="form-input" placeholder="输入密码" maxlength="50" required autocomplete="current-password">
      </div>
      <button type="submit" class="btn btn-primary btn-block">登录</button>
    </form>
    <a href="/" class="auth-back">&larr; 返回首页</a>
  </div>
</div>
</div></section>
<%- include('../partials/footer') %>
