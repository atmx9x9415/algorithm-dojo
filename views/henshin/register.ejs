<%- include('../partials/header', { title: '注册' }) %>
<section class="section"><div class="container">
<div class="auth-wrapper">
  <div class="auth-card">
    <h2 class="auth-title">注册账号</h2>
    <p class="auth-subtitle">注册后即可上传题目和题解</p>
    <div class="auth-links"><span>已有账号？</span><a href="/henshin">去登录</a></div>
    <% if (typeof error !== 'undefined' && error) { %><div class="alert alert-error"><%= error %></div><% } %>
    <form method="POST" action="/henshin/register" class="auth-form">
      <div class="form-group">
        <label for="email">邮箱</label>
        <input type="email" id="email" name="email" class="form-input" value="<%= typeof email !== 'undefined' ? email : '' %>" placeholder="your@email.com" maxlength="100" required autocomplete="email">
      </div>
      <div class="form-group">
        <label for="password">密码（至少6位）</label>
        <input type="password" id="password" name="password" class="form-input" placeholder="至少6位" maxlength="50" required autocomplete="new-password">
      </div>
      <div class="form-group">
        <label for="password2">确认密码</label>
        <input type="password" id="password2" name="password2" class="form-input" placeholder="再次输入密码" maxlength="50" required autocomplete="new-password">
      </div>
      <button type="submit" class="btn btn-primary btn-block">注册</button>
    </form>
    <a href="/" class="auth-back">&larr; 返回首页</a>
  </div>
</div>
</div></section>
<%- include('../partials/footer') %>
